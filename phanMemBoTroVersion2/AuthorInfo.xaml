<UserControl x:Class="phanMemBoTroVersion2.AuthorInfo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Background="#FFFFFBEA">
        <ScrollViewer>
            <StackPanel
                Margin="5">

                <TextBlock x:Name="TxtAuthor"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#2a5534"
                           HorizontalAlignment="Center"/>

                <Image x:Name="ImgAuthor"
                       Height="150"
                       Margin="0,10"
                       Stretch="Uniform"/>

                <TextBlock Text="Thông tin tác giả"
                       FontWeight="Bold"
                       Margin="0,10"/>

                <ItemsControl x:Name="AuthorInfoList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       TextWrapping="Wrap"
                                       Margin="5,6"
                                       FontSize="15"
                                       LineHeight="24"
                                       TextAlignment="Justify"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Thông tin bài hát"
                       FontWeight="Bold"
                       Margin="0,10"/>

                <ItemsControl x:Name="SongInfoList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       TextWrapping="Wrap"
                                       Margin="5,6"
                                       FontSize="15"
                                       LineHeight="24"
                                       TextAlignment="Justify"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ui:Button Content="Đóng"
                           Appearance="Danger"
                           Margin="0,20"
                           Padding="20,10"
                           HorizontalAlignment="Center"
                           Click="BtnClose_Click">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="TextAsterisk16"/>
                    </ui:Button.Icon>
                </ui:Button>

            </StackPanel>

        </ScrollViewer>
    </Grid>

</UserControl>