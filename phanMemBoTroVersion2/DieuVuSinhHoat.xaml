<UserControl x:Class="phanMemBoTroVersion2.DieuVuSinhHoat"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:phanMemBoTroVersion2"
             mc:Ignorable="d" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             KeyDown="UserControl_KeyDown"
             Focusable="True">
    <Grid Background="#FFFFFBEA">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- SIDEBAR -->
        <DockPanel Grid.Column="0">

            <StackPanel>

                <Grid Margin="20,10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ui:Button Width="40"
                           Height="40"
                           Appearance="Success"
                           HorizontalContentAlignment="Center"
                           VerticalContentAlignment="Center"
                           Click="BtnBack_Click">
                        <ui:Button.Icon >
                            <ui:SymbolIcon FontSize="20" 
                                       Symbol="ArrowCircleLeft24"/>
                        </ui:Button.Icon>
                    </ui:Button>

                    <TextBlock Grid.Column="1"
                           Text="Vũ Điệu Sinh Hoạt"
                           Margin="12,0"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#6B8E23"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                </Grid>

                <Border Height="1"
                        Margin="12,8"
                        Background="#2a5534"/>

                <ListBox x:Name="SidebarMenu"
                         SelectionChanged="SidebarMenu_SelectionChanged"
                         DisplayMemberPath="title"/>

            </StackPanel>

        </DockPanel>


        <!-- CONTENT -->
        <Grid Grid.Column="1" Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tên vũ điệu -->
            <StackPanel Margin="0,0,0,10"
                HorizontalAlignment="Center">

                <TextBlock x:Name="TxtTenVuDieu"
                   FontSize="32"
                   FontWeight="Bold"
                   Foreground="#2a5534"
                   HorizontalAlignment="Center"/>

            </StackPanel>

            <!-- VIDEO -->
            <Grid Grid.Row="1">

                    <MediaElement x:Name="VideoPlayer"
                          LoadedBehavior="Manual"
                          Stretch="Uniform"
                          MediaOpened="VideoPlayer_MediaOpened"
                          MediaEnded="VideoPlayer_MediaEnded"/>

            </Grid>

            <!-- CONTROL -->
            <StackPanel Grid.Row="2">

                <DockPanel Margin="0,5">

                    <TextBlock x:Name="TxtCurrentTime"
                       Text="00:00"
                       DockPanel.Dock="Left"
                       Margin="0,0,10,0"
                       VerticalAlignment="Center"/>

                    <TextBlock x:Name="TxtTotalTime"
                       Text="00:00"
                       DockPanel.Dock="Right"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"/>

                    <Slider x:Name="MusicProgress"
                    Minimum="0"
                    Maximum="100"
                    ValueChanged="MusicProgress_ValueChanged"/>

                </DockPanel>

                <!-- BUTTONS -->

                <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10">

                    <ui:Button Width="40"
                       Height="40"
                       Click="BtnPrev_Click">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Previous24"/>
                        </ui:Button.Icon>
                    </ui:Button>

                    <ui:Button Width="40"
                       Height="40"
                       Margin="10,0"
                       Click="BtnPlayPause_Click">

                        <ui:Button.Icon>
                            <ui:SymbolIcon x:Name="IconPlayPause"
                                   Symbol="Play24"/>
                        </ui:Button.Icon>

                    </ui:Button>

                    <ui:Button Width="40"
                       Height="40"
                       Click="BtnNext_Click">

                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Next24"/>
                        </ui:Button.Icon>

                    </ui:Button>

                </StackPanel>

            </StackPanel>

        </Grid>
    </Grid>
</UserControl>
