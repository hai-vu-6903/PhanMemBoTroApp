<UserControl x:Class="phanMemBoTroVersion2.BaiHat"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             KeyDown="UserControl_KeyDown"
             Focusable="True">
    <UserControl.Resources>

        <Storyboard x:Key="OpenPanel">

            <DoubleAnimation
            Storyboard.TargetName="InfoPanel"
            Storyboard.TargetProperty="Width"
            From="0"
            To="600"
            Duration="0:0:0.3"/>

        </Storyboard>


        <Storyboard x:Key="ClosePanel">

            <DoubleAnimation
            Storyboard.TargetName="InfoPanel"
            Storyboard.TargetProperty="Width"
            From="600"
            To="0"
            Duration="0:0:0.3"/>

        </Storyboard>

    </UserControl.Resources>
    <Grid Background="#FFFFFBEA">
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="InfoColumn" Width="Auto"/>
        </Grid.ColumnDefinitions>
        <!-- SIDEBAR -->
        <DockPanel Grid.Column="0">

            <StackPanel>

                <Grid Margin="20,10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ui:Button Width="40"
                               Height="40"
                               Appearance="Success"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               Click="BtnBack_Click">
                        <ui:Button.Icon >
                            <ui:SymbolIcon FontSize="20" 
                                           Symbol="ArrowCircleLeft24"/>
                        </ui:Button.Icon>
                    </ui:Button>

                    <TextBlock Grid.Column="1"
                               Text="Bài Hát Quy Định"
                               Margin="12,0"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#6B8E23"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                </Grid>

                <Border Height="1"
                    Margin="12,8"
                    Background="#2a5534"/>

                <ListBox x:Name="SidebarMenu"
                     SelectionChanged="SidebarMenu_SelectionChanged"
                     DisplayMemberPath="title"/>

            </StackPanel>

        </DockPanel>


        <!-- CONTENT -->

        <Grid Grid.Column="1" Margin="30">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Margin="0,0,0,20"
                        HorizontalAlignment="Center">

                <TextBlock x:Name="TxtTenBaiHat"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="#2a5534"
                           HorizontalAlignment="Center"/>

                <!-- Tên tác giả -->
                <TextBlock x:Name="TxtTacGia"
                           FontSize="18"
                           Foreground="Gray"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"/>

                <!-- Link xem thông tin -->
                <Button Click="TxtInfo_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        HorizontalAlignment="Center">

                    <TextBlock Text="Xem thông tin bài hát và tác giả"
                               Foreground="#1E90FF"
                               FontSize="14"
                               TextDecorations="Underline"/>
                </Button>

            </StackPanel>
            <ListBox x:Name="LyricsList"
                     Grid.Row="1"
                     FontSize="48"
                     FontWeight="Bold"
                     BorderThickness="0"
                     Background="Transparent"
                     HorizontalContentAlignment="Center"
                     VerticalContentAlignment="Center"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="LyricsList_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">

                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="20"/>
                        <Setter Property="Margin" Value="0,10"/>
                        <Setter Property="FontSize" Value="40"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Foreground" Value="#999999"/>

                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Setter.Value>
                        </Setter>

                        <Style.Triggers>

                            <!-- dòng đang hát -->
                            <Trigger Property="IsSelected" Value="True">

                                <Setter Property="Background" Value="#332a5534"/>
                                <Setter Property="Foreground" Value="#2a5534"/>

                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                    </Setter.Value>
                                </Setter>

                            </Trigger>

                        </Style.Triggers>

                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel VerticalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <!-- In lời -->
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Text}"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   FontSize="30"
                   LineHeight="50"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2">

                <DockPanel Margin="0,5">

                    <!-- TIME LEFT -->
                    <TextBlock x:Name="TxtCurrentTime"
                               Text="00:00"
                               DockPanel.Dock="Left"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"/>

                    <!-- TIME RIGHT -->
                    <TextBlock x:Name="TxtTotalTime"
                               Text="00:00"
                               DockPanel.Dock="Right"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"/>

                    <!-- PROGRESS (ở giữa) -->
                    <Slider x:Name="MusicProgress"
                            Minimum="0"
                            Maximum="100"
                            ValueChanged="MusicProgress_ValueChanged"
                            VerticalAlignment="Center"/>

                </DockPanel>
                <!-- BUTTONS -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10">

                    <ui:Button Height="40"
                               Width="40"
                               Click="BtnPrev_Click">

                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Previous24"/>
                        </ui:Button.Icon>

                    </ui:Button>


                    <ui:Button Height="40"
                               Width="40"
                               Click="BtnPlayPause_Click"
                   Margin="10,0">

                        <ui:Button.Icon>
                            <ui:SymbolIcon x:Name="IconPlayPause"
                               Symbol="Play24"/>
                        </ui:Button.Icon>

                    </ui:Button>


                    <ui:Button Height="40"
                               Width="40" 
                               Click="BtnNext_Click">

                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Next24"/>
                        </ui:Button.Icon>

                    </ui:Button>

                </StackPanel>

                <MediaElement x:Name="Player"
                              LoadedBehavior="Manual"
                              MediaEnded="Player_MediaEnded"/>

            </StackPanel>
        </Grid>
        
        <Border Grid.Column="2"
                x:Name="InfoPanel"
                Width="0"
                MaxWidth="600"
                Background="White"
                BorderBrush="#DDD"
                BorderThickness="1">

            <ContentControl x:Name="InfoContent"/>

        </Border>
    </Grid>
</UserControl>