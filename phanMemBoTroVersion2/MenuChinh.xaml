<UserControl x:Class="phanMemBoTroVersion2.MenuChinh"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="Transparent">

    <Grid>

        <!-- chia layout -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- ================= HEADER ================= -->
        <Grid Grid.Row="0" Background="#FF970A0A">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image Source="/Images/logo.png"
                   Height="70"
                   Margin="20,0"/>

            <TextBlock Grid.Column="1"
                       Text="PHÒNG CHỐNG TỐT – CHIẾN ĐẤU GIỎI"
                       FontSize="46"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#FFD700"/>

            <Image Grid.Column="2"
                   Source="/Images/logo2.png"
                   Height="50"
                   Margin="20,0"/>

            <Rectangle Height="2"
                       Fill="#FFD700"
                       VerticalAlignment="Bottom"
                       Grid.ColumnSpan="3"/>

        </Grid>


        <!-- ================= BODY ================= -->
        <Grid Grid.Row="1">

            <!-- chia 3 cột -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="0.3*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="0.3*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>


            <!-- ===== BACKGROUND IMAGES ===== -->

            <!-- Ảnh trái -->
            <Grid Grid.Column="0">
                <Image Source="/Images/menuScreen1.png"
               Stretch="UniformToFill"/>

                <!-- fade -->
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF005037" Offset="0"/>
                            <GradientStop Color="#00005037" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>


            <!-- Ảnh giữa -->
            <Grid Grid.Column="2">
                <Image Source="/Images/menuScreen3.png"
               Stretch="UniformToFill"/>
            </Grid>


            <!-- Ảnh phải -->
            <Grid Grid.Column="4">
                <Image Source="/Images/menuScreen5.png"
               Stretch="UniformToFill"/>

                <!-- fade -->
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="1,0" EndPoint="0,0">
                            <GradientStop Color="#FF005037" Offset="0"/>
                            <GradientStop Color="#00005037" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>


            <!-- ===== CONTENT NỔI LÊN TRÊN ===== -->
            <Border Grid.Column="0"
                    Grid.ColumnSpan="5"
                    CornerRadius="12"
                    Padding="40"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Panel.ZIndex="1">
                <Border.Background>
                    <ImageBrush ImageSource="/Images/bgMenu.png"/>
                </Border.Background>

                <StackPanel>

                    <TextBlock Text="NỘI DUNG BỔ TRỢ CHO HẠ SĨ QUAN, BINH SĨ"
                               FontSize="40"
                               FontWeight="Bold"
                               Foreground="#005037"
                               TextAlignment="Center"
                               Margin="0,0,0,20">
                        <!--<TextBlock.Effect>
                            <DropShadowEffect Color="Yellow" BlurRadius="6" ShadowDepth="2"/>
                        </TextBlock.Effect>-->
                    </TextBlock>
                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ui:Button Grid.Row="0" Grid.Column="0"
                                   Content="Bài Hát Quy Định"
                                   Margin="10"
                                   Padding="10,20"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   Appearance="Primary"
                                   Click="BtnBaiHat_Click"/>

                        <ui:Button Grid.Row="0" Grid.Column="1"
                                   Content="5 Điệu Vũ Sinh Hoạt Tập Thể"
                                   Margin="10"
                                   Padding="10,20"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   Appearance="Caution"
                                   Click="BtnVuSinhHoat_Click"/>

                        <ui:Button Grid.Row="1" Grid.Column="0"
                                   Content="Câu Hỏi Trắc Nghiệm"
                                   Margin="10"
                                   Padding="10,20"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   Appearance="Success"
                                   Click="BtnTracNghiem_Click"/>

                        <ui:Button Grid.Row="1" Grid.Column="1"
                                   Content="Bảo Tàng Lịch Sử Quân Sự"
                                   Margin="10"
                                   Padding="10,20"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   Appearance="Danger"
                                   Click="BtnBaoTang_Click"/>

                    </Grid>
                </StackPanel>

            </Border>
        </Grid>
    </Grid>
</UserControl>